print("Welcome to FizzBuzz!")
def fizzbuzz(n):
    if n % 3 == 0 and n % 7 == 0:
        return "FizzBuzz"
    elif n % 7 == 0:
        return "Buzz"
    elif n % 3 == 0:
        return "Fizz"
    else:
        return str(n)
    
number = int(input())
print(fizzbuzz(number))
    